        {
          "name": "Refresh Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response = pm.response.json();\r",
                  "let accessToken = response.data?.accessToken;\r",
                  "pm.environment.set(\"JWT\", accessToken);\r",
                  "\r",
                  "let refreshToken = response.data?.refreshToken;\r",
                  "if (refreshToken) pm.environment.set(\"REFRESH_TOKEN\", refreshToken);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{REFRESH_TOKEN}}\"\n}"
            },
            "url": {
              "raw": "{{MainHost}}/api/v1/auth/refresh",
              "host": ["{{MainHost}}"],
              "path": ["api", "v1", "auth", "refresh"]
            }
